{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "lib": ["ES2024", "DOM"],
    "jsx": "react-jsx",
    "types": ["node", "react"],
    "noEmit": true
  },
  "include": ["src/**/*"]
}
